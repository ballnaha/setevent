generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
}

model blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique(map: "Blog_slug_key")
  excerpt     String?  @db.Text
  content     String?  @db.Text
  coverImage  String?  @db.Text
  author      String?  @default("Admin")
  category    String?  @default("General")
  views       Int      @default(0)
  status      String   @default("published")
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model booking {
  id          String   @id @default(cuid())
  eventId     String
  serviceName String
  quantity    Int      @default(1)
  price       Decimal? @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "Booking_eventId_fkey")

  @@index([eventId], map: "Booking_eventId_fkey")
}

model category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique(map: "Category_slug_key")
  description    String?    @db.Text
  image          String?
  parentId       String?
  order          Int        @default(0)
  status         String     @default("active")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime @updatedAt
  parent         category?  @relation("categoryTocategory", fields: [parentId], references: [id], map: "Category_parentId_fkey")
  children       category[] @relation("categoryTocategory")
  products       product[]

  @@index([parentId], map: "Category_parentId_fkey")
}

model chatlog {
  id          String   @id
  customerId  String
  message     String   @db.Text
  direction   String
  messageType String   @default("text")
  eventId     String?
  createdAt   DateTime @default(now())
  customer    customer @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "ChatLog_customerId_fkey")
  event       event?   @relation(fields: [eventId], references: [id], map: "ChatLog_eventId_fkey")

  @@index([customerId], map: "ChatLog_customerId_fkey")
  @@index([eventId], map: "ChatLog_eventId_fkey")
}

model customer {
  id                String    @id @default(cuid())
  lineUid           String    @unique(map: "Customer_lineUid_key")
  displayName       String?
  pictureUrl        String?
  phone             String?
  email             String?
  companyName       String?
  status            String    @default("new")
  lastActiveEventId String?
  firstMessageAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime @updatedAt
  chatlog           chatlog[]
  event             event[]
}

model design {
  id          String   @id @default(cuid())
  title       String
  category    String
  image       String?  @db.Text
  description String?  @db.Text
  likes       Int      @default(0)
  views       Int      @default(0)
  status      String   @default("active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model event {
  id            String          @id @default(cuid())
  customerId    String
  eventName     String
  inviteCode    String          @unique(map: "Event_inviteCode_key")
  eventDate     DateTime?
  venue         String?
  description   String?         @db.Text
  status        String          @default("draft")
  totalPrice    Decimal?        @db.Decimal(12, 2)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime @updatedAt
  salesId       String?
  booking       booking[]
  chatlog       chatlog[]
  customer      customer        @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "Event_customerId_fkey")
  user          user?           @relation(fields: [salesId], references: [id], map: "Event_salesId_fkey")
  eventtimeline eventtimeline[]
  review        review?

  @@index([customerId], map: "Event_customerId_fkey")
  @@index([salesId], map: "Event_salesId_fkey")
}

model eventtimeline {
  id          String    @id @default(cuid())
  eventId     String
  title       String
  description String?
  images      String?   @db.Text
  progress    Int?
  status      String    @default("pending")
  order       Int       @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  event       event     @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "EventTimeline_eventId_fkey")

  @@index([eventId], map: "EventTimeline_eventId_fkey")
}

model faq {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  category  String   @default("ทั่วไป")
  status    String   @default("active")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model portfolio {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique(map: "Portfolio_slug_key")
  category    String
  image       String?
  description String?  @db.Text
  likes       Int      @default(0)
  views       Int      @default(0)
  status      String   @default("active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      portfolioimage[]
}

model portfolioimage {
  id          String    @id @default(cuid())
  portfolioId String
  url         String    @db.Text
  caption     String?   @db.Text
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  portfolio   portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade, map: "PortfolioImage_portfolioId_fkey")

  @@index([portfolioId], map: "PortfolioImage_portfolioId_fkey")
}

model product {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  slug        String   @unique(map: "Product_slug_key")
  description String?  @db.Text
  price       Decimal? @db.Decimal(12, 2)
  priceUnit   String?
  status      String   @default("active")
  images      String?  @db.Text
  features    String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    category @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "Product_categoryId_fkey")

  @@index([categoryId], map: "Product_categoryId_fkey")
}

model promotion {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  image       String?
  price       String?
  period      String?
  features    String?  @db.Text
  category    String?  // e.g. "งานแต่ง", "เช่าจอ LED"
  status      String   @default("active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?  @db.Text
  eventId   String   @unique(map: "Review_eventId_key")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "Review_eventId_fkey")
}

model session {
  id           String   @id
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
}

model sitesettings {
  id        String   @id @default(cuid())
  key       String   @unique(map: "SiteSettings_key_key")
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model user {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique(map: "User_email_key")
  emailVerified DateTime?
  image         String?
  username      String?   @unique(map: "User_username_key")
  password      String?
  role          String    @default("admin")
  position      String?
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt
  account       account[]
  event         event[]
  session       session[]
}

model valentinecard {
  id                       String             @id @default(cuid())
  slug                     String             @unique(map: "ValentineCard_slug_key")
  jobName                  String?
  title                    String
  openingText              String?
  greeting                 String?
  subtitle                 String?
  message                  String?            @db.Text
  signer                   String?
  backgroundColor          String?            @default("#FFF0F3")
  status                   String             @default("active")
  disabledAt               DateTime?
  backgroundMusicYoutubeId String?
  backgroundMusicUrl       String?            @db.Text
  swipeHintColor           String?            @default("white")
  swipeHintText            String?            @default("Swipe to see more")
  showGame                 Boolean            @default(true)
  customerPhone            String?
  customerAddress          String?            @db.Text
  note                     String?            @db.Text
  createdAt                DateTime           @default(now())
  updatedAt                DateTime @updatedAt
  memories                 valentinememory[]
  scores                   valentinescore[]
  orderedProducts          valentineproduct[] @relation("valentinecardtovalentineproduct")
}

model valentinememory {
  id            String        @id @default(cuid())
  cardId        String
  type          String        @default("image")
  url           String        @db.Text
  caption       String?
  thumbnail     String?       @db.Text
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime @updatedAt
  valentinecard valentinecard @relation(fields: [cardId], references: [id], onDelete: Cascade, map: "ValentineMemory_cardId_fkey")

  @@index([cardId], map: "ValentineMemory_cardId_fkey")
}

model valentineproduct {
  id                    String                  @id @default(cuid())
  name                  String
  category              String                  @default("General")
  price                 Float
  originalPrice         Float?
  description           String?                 @db.Text
  image                 String?
  isHot                 Boolean                 @default(false)
  isNew                 Boolean                 @default(false)
  status                String                  @default("active")
  order                 Int                     @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime @updatedAt
  images                valentineproductimage[]
  valentinecard         valentinecard[]         @relation("valentinecardtovalentineproduct")
}

model valentineproductimage {
  id               String           @id @default(cuid())
  productId        String
  url              String           @db.Text
  order            Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime @updatedAt
  valentineproduct valentineproduct @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ValentineProductImage_productId_fkey")

  @@index([productId], map: "ValentineProductImage_productId_fkey")
}

model valentinescore {
  id            String        @id
  cardId        String
  playerId      String
  name          String
  score         Int
  createdAt     DateTime      @default(now())
  valentinecard valentinecard @relation(fields: [cardId], references: [id], onDelete: Cascade, map: "ValentineScore_cardId_fkey")

  @@unique([cardId, playerId], map: "ValentineScore_cardId_playerId_key")
  @@index([cardId], map: "ValentineScore_cardId_idx")
  @@index([playerId], map: "ValentineScore_playerId_idx")
  @@index([score(sort: Desc)], map: "ValentineScore_score_idx")
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
}
